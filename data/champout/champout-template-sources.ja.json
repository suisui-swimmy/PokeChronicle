{
  "schemaVersion": "0.1.0",
  "language": "jpn",
  "maxGeneratedRules": 600,
  "sources": [
    {
      "fileName": "btl_attack_syn.json",
      "status": "enabled",
      "reason": "standard actor move messages",
      "labelAllowPatterns": ["^ATKMSG_"],
      "labelDenyPatterns": ["INFO", "TUTORIAL", "HELP", "BUTTON", "SELECT"],
      "textDenyHints": [],
      "eventTypeRules": [
        {
          "eventType": "move",
          "when": {
            "fileName": "btl_attack_syn.json"
          }
        }
      ],
      "placeholderPolicy": {
        "default": ["pokemon", "move", "text"]
      }
    },
    {
      "fileName": "btl_std.json",
      "status": "enabled",
      "reason": "standard live battle messages",
      "labelDenyPatterns": ["INFO", "TUTORIAL", "HELP", "BUTTON", "SELECT"],
      "textDenyHints": [],
      "eventTypeRules": []
    },
    {
      "fileName": "btl_set.json",
      "status": "enabled",
      "reason": "narrow live battle resolution messages for status, stat rank, faint, flinch, item priority, effectiveness, fail, redirection, mega evolution, weather damage, and tea effect",
      "labelAllowPatterns": [
        "^BTL_STRID_SET_(Dead|ShrinkExe|NoEffect|AffGood_1|DokuGet|YakedoGet|MahiGet|KoriGet|NemuriGet|MeromeroGet|KonranGet|DokuCure|YakedoCure|MahiCure|KoriMelt|NemuriWake|KonranCure|MeromeroCure|UseItem_Cure(Doku|Mahi|Nemuri|Koori|Yakedo|Konran|Mero)|UseItem_PriorityUpOnce|WazaFailPoke|FushokugasuMiss|WeatherDmg_Sand|Konoyubi|MegaEvo|MotenashiNoKokoro)(_E)?$|^BTL_STRID_SET_Rank(up|down)Lv[12]_1_(P|E)_syn$"
      ],
      "labelDenyPatterns": ["Already", "Act$", "Damage", "TUTORIAL", "HELP", "BUTTON", "SELECT"],
      "textDenyHints": [],
      "eventTypeRules": [
        {
          "eventType": "faint",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_Dead(_E)?$"]
          }
        },
        {
          "eventType": "immune",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_NoEffect(_E)?$"]
          }
        },
        {
          "eventType": "supereffective",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_AffGood_1(_E)?$"]
          }
        },
        {
          "eventType": "flinch",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_ShrinkExe(_E)?$"]
          }
        },
        {
          "eventType": "item",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_UseItem_PriorityUpOnce(_E)?$"]
          }
        },
        {
          "eventType": "fail",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_(WazaFailPoke|FushokugasuMiss)(_E)?$"]
          }
        },
        {
          "eventType": "damage",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_WeatherDmg_Sand(_E)?$"]
          }
        },
        {
          "eventType": "redirection",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_Konoyubi(_E)?$"]
          }
        },
        {
          "eventType": "activate",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_(MegaEvo|MotenashiNoKokoro)(_E)?$"]
          }
        },
        {
          "eventType": "boost",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_RankupLv[12]_1_(P|E)_syn$"]
          }
        },
        {
          "eventType": "unboost",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_RankdownLv[12]_1_(P|E)_syn$"]
          }
        },
        {
          "eventType": "status_cure",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_(DokuCure|YakedoCure|MahiCure|KoriMelt|NemuriWake|KonranCure|MeromeroCure|UseItem_Cure(Doku|Mahi|Nemuri|Koori|Yakedo|Konran|Mero))(_E)?$"]
          }
        },
        {
          "eventType": "status",
          "when": {
            "labelPatterns": ["^BTL_STRID_SET_(DokuGet|YakedoGet|MahiGet|KoriGet|NemuriGet|MeromeroGet|KonranGet)(_E)?$"]
          }
        }
      ],
      "placeholderPolicy": {
        "byEventType": {
          "immune": ["target", "text"],
          "supereffective": ["target", "text"]
        },
        "byLabelPattern": [
          {
            "pattern": "^BTL_STRID_SET_(WazaFailPoke|FushokugasuMiss)(_E)?$",
            "slots": ["target", "text"]
          },
          {
            "pattern": "^BTL_STRID_SET_WeatherDmg_Sand(_E)?$",
            "slots": ["target", "text"]
          },
          {
            "pattern": "^BTL_STRID_SET_MegaEvo(_E)?$",
            "slots": ["pokemon", "text"]
          },
          {
            "pattern": "^BTL_STRID_SET_MotenashiNoKokoro(_E)?$",
            "slots": ["pokemon", "target", "text"]
          },
          {
            "pattern": "^BTL_STRID_SET_UseItem_PriorityUpOnce(_E)?$",
            "slots": ["pokemon", "text"]
          },
          {
            "pattern": "^BTL_STRID_SET_Rank(up|down)Lv[12]_1_(P|E)_syn$",
            "slotsByIndex": {
              "0": "pokemon",
              "4": "stat"
            }
          }
        ]
      }
    }
  ]
}
